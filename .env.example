# Copy this file to .env and set real values for your provider.
# cp .env.example .env

# Django runtime settings
DEBUG=false
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
ALLOWED_HOSTS=invite.afineman.com
CSRF_TRUSTED_ORIGINS=https://invite.afineman.com
SECURE_SSL_REDIRECT=true

# Force SMTP backend (real email delivery)
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# Sender shown in invitation emails
DEFAULT_FROM_EMAIL=Your Event <noreply@yourdomain.com>

# SMTP connection details
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_TLS=true
EMAIL_USE_SSL=false
EMAIL_HOST_USER=your_smtp_username
EMAIL_HOST_PASSWORD=your_smtp_password
